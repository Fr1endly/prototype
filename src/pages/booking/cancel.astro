---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
---

<Layout title="Booking Cancelled | Inspirit Lactation" activePage="book">

  <section class="max-w-2xl mx-auto px-6 py-24 text-center">
    <div class="flex items-center justify-center mb-6">
      <div class="w-16 h-16 rounded-full bg-sand flex items-center justify-center">
        <svg class="w-8 h-8 text-espresso/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </div>
    </div>
    <h1 class="font-display text-4xl md:text-5xl font-[300] text-espresso mb-4">
      Booking <span class="italic text-blush">Not Completed</span>
    </h1>
    <p class="text-sm text-espresso/70 font-[300] leading-relaxed mb-8">
      It looks like the payment wasn't completed. No worries — your spot hasn't been charged.
      You can try again whenever you're ready.
    </p>
    <div class="flex flex-wrap items-center justify-center gap-4">
      <a
        href="/book/"
        class="inline-block bg-blush text-cream text-xs tracking-[0.25em] uppercase px-8 py-3 border border-blush hover:bg-transparent hover:text-blush transition-all duration-300"
      >
        Try Again
      </a>
      <a
        href="/"
        class="inline-block border border-espresso text-espresso text-xs tracking-[0.25em] uppercase px-8 py-3 hover:bg-espresso hover:text-cream transition-all duration-300"
      >
        Back to Home
      </a>
    </div>
  </section>

</Layout>
