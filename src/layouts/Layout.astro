---
interface Props {
  title: string;
  activePage: 'home' | 'about' | 'faq' | 'resources' | 'book' | 'classes';
}

const { title, activePage } = Astro.props;

const navItems = [
  { label: 'Home',             href: '/',          key: 'home' },
  { label: 'About',            href: '/about/',    key: 'about' },
  { label: 'Classes',          href: '/classes/',  key: 'classes' },
  { label: 'Book Now',         href: '/book/',     key: 'book' },
  // { label: 'FAQ',              href: '/#faq',      key: 'faq' },
  // { label: 'Online Resources', href: '/#resources', key: 'resources' },
] as const;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet" />
</head>
<body class="font-body text-espresso">

  <!-- ───── NAV ───── -->
  <header class="sticky top-0 z-50 bg-cream/90 backdrop-blur-sm border-b border-sand shadow-sm">
    <div class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between">
      <a href="/" class="font-display text-xl tracking-widest uppercase text-espresso">
        Inspirit Lactation
      </a>
      <nav class="hidden md:flex items-center gap-8 text-sm tracking-widest uppercase font-body font-[500]">
        {navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              'nav-link transition-colors',
              activePage === item.key ? 'text-blush' : 'hover:text-blush',
            ]}
          >
            {item.label}
          </a>
        ))}
      </nav>
      <!-- Mobile hamburger -->
      <button id="menu-btn" class="md:hidden flex flex-col gap-1.5 p-1" aria-label="Open menu">
        <span class="w-5 h-px bg-espresso block"></span>
        <span class="w-5 h-px bg-espresso block"></span>
        <span class="w-5 h-px bg-espresso block"></span>
      </button>
    </div>
    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden md:hidden bg-cream border-t border-sand px-6 py-4 flex flex-col gap-4 text-sm tracking-widest uppercase font-[500]">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            'transition-colors',
            activePage === item.key ? 'text-blush' : 'hover:text-blush',
          ]}
        >
          {item.label}
        </a>
      ))}
    </div>
  </header>

  <main>
    <slot />
  </main>

  <!-- ───── FOOTER ───── -->
  <footer class="bg-espresso text-cream/70">
    <div class="max-w-5xl mx-auto px-6 py-10 flex flex-col md:flex-row items-center justify-between gap-6">
      <p class="font-display italic text-lg text-cream/50">Inspirit Lactation</p>
      <p class="text-xs tracking-widest uppercase text-cream/40 font-[300]">©2019 by Inspirit Lactation</p>
      <!-- Social icons -->
      <div class="flex items-center gap-5">
        <!-- Facebook -->
        <a href="https://www.facebook.com" target="_blank" aria-label="Facebook"
           class="w-8 h-8 rounded-full border border-cream/20 flex items-center justify-center hover:border-blush hover:text-blush transition-colors">
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
          </svg>
        </a>
        <!-- Twitter/X -->
        <a href="https://twitter.com" target="_blank" aria-label="Twitter"
           class="w-8 h-8 rounded-full border border-cream/20 flex items-center justify-center hover:border-blush hover:text-blush transition-colors">
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"/>
          </svg>
        </a>
        <!-- LinkedIn -->
        <a href="https://linkedin.com" target="_blank" aria-label="LinkedIn"
           class="w-8 h-8 rounded-full border border-cream/20 flex items-center justify-center hover:border-blush hover:text-blush transition-colors">
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"/>
            <circle cx="4" cy="4" r="2"/>
          </svg>
        </a>
      </div>
    </div>
  </footer>

  <script>
    // Mobile nav toggle
    document.getElementById('menu-btn')?.addEventListener('click', () => {
      document.getElementById('mobile-menu')?.classList.toggle('hidden');
    });

    // Scroll reveal
    const revealEls = document.querySelectorAll('.reveal');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          observer.unobserve(e.target);
        }
      });
    }, { threshold: 0.15 });
    revealEls.forEach(el => observer.observe(el));
  </script>

  <!-- Cloudflare Web Analytics -->
  <script defer src="https://static.cloudflareinsights.com/beacon.min.js"
    data-cf-beacon='{"token": "YOUR_TOKEN_HERE"}'></script>
</body>
</html>
